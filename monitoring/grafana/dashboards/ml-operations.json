{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Experiments Completed Over Time",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(forge_experiments_total{status=\"completed\"}[1h])",
          "legendFormat": "{{model_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Training Duration by Model Type",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "options": {
        "calculate": false,
        "color": {
          "scheme": "Oranges"
        }
      },
      "targets": [
        {
          "expr": "rate(forge_training_duration_seconds_bucket[5m])",
          "legendFormat": "{{model_type}} {{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Inference Latency by Model Type",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(forge_inference_latency_seconds_bucket[5m])",
          "legendFormat": "{{model_type}} {{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Model Registry Stage Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "forge_model_registry_versions",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latest Drift Scores",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "orange", "value": 0.25 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        }
      ],
      "targets": [
        {
          "expr": "forge_drift_score",
          "legendFormat": "{{dataset}} / {{feature}}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["forge", "ml"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "ML Operations",
  "uid": "forge-ml-operations"
}
