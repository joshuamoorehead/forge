{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Total API Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[24h]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{status=~\"[45]..\"}[24h])) / sum(increase(http_requests_total[24h]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Experiments Run (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(forge_experiments_total[24h]))",
          "legendFormat": "Experiments",
          "refId": "A"
        }
      ]
    },
    {
      "title": "LLM Cost (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "forge_llm_cost_dollars_total",
          "legendFormat": "Cost",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Data Ingestion Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(forge_data_ingestion_rows_total[5m])",
          "legendFormat": "{{ticker}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "LLM Cost Accumulation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "forge_llm_cost_dollars_total",
          "legendFormat": "Cumulative Cost",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ops Errors by Project",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "forge-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "stacking": "normal"
      },
      "targets": [
        {
          "expr": "increase(forge_ops_errors_total[1h])",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["forge", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Platform Overview",
  "uid": "forge-platform-overview"
}
