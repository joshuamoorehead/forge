# Database
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# Weights & Biases (free for personal use)
WANDB_API_KEY=your_wandb_key

# AWS S3 (for artifact storage)
AWS_ACCESS_KEY_ID=your_aws_key
